# Resend API key for contact form emails
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Public site URL for SEO metadata and canonical URLs
# Local dev: use http://localhost:3000 in .env.local
# Production: set to https://coolwebstudio.com in Vercel (or your host) env vars
NEXT_PUBLIC_SITE_URL=https://coolwebstudio.com
